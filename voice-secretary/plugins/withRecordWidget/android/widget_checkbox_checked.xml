<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2563EB" />
            <corners android:radius="3dp" />
            <size
                android:width="16dp"
                android:height="16dp" />
        </shape>
    </item>
    <item
        android:bottom="4dp"
        android:left="3dp"
        android:right="3dp"
        android:top="5dp">
        <rotate
            android:fromDegrees="45"
            android:pivotX="50%"
            android:pivotY="50%"
            android:toDegrees="45">
            <shape android:shape="rectangle">
                <solid android:color="#FFFFFF" />
                <size
                    android:width="3dp"
                    android:height="7dp" />
            </shape>
        </rotate>
    </item>
    <item
        android:bottom="4dp"
        android:left="6dp"
        android:right="8dp"
        android:top="8dp">
        <rotate
            android:fromDegrees="-45"
            android:pivotX="50%"
            android:pivotY="50%"
            android:toDegrees="-45">
            <shape android:shape="rectangle">
                <solid android:color="#FFFFFF" />
                <size
                    android:width="3dp"
                    android:height="4dp" />
            </shape>
        </rotate>
    </item>
</layer-list>
