<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_today_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_panel_bg"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_today_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="오늘 일정"
            android:textColor="#F8FAFC"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_today_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0건"
            android:textColor="#93C5FD"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_today_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="오늘 등록된 일정이 없습니다"
        android:textColor="#94A3B8"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/widget_schedule_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_schedule_1_time"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="09:00"
            android:textColor="#93C5FD"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_schedule_1_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="일정"
            android:textColor="#F8FAFC"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_schedule_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_schedule_2_time"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="10:00"
            android:textColor="#93C5FD"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_schedule_2_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="일정"
            android:textColor="#F8FAFC"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_schedule_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_schedule_3_time"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="11:00"
            android:textColor="#93C5FD"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_schedule_3_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="일정"
            android:textColor="#F8FAFC"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_schedule_row_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_schedule_4_time"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="12:00"
            android:textColor="#93C5FD"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_schedule_4_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="일정"
            android:textColor="#F8FAFC"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_schedule_more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="외 1건 더 있음"
        android:textColor="#64748B"
        android:textSize="11sp"
        android:visibility="gone" />
</LinearLayout>
