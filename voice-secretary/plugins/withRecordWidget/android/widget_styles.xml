<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="WidgetCalendarWeekday">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#64748B</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="WidgetCalendarRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="WidgetCalendarDay">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">1dp</item>
        <item name="android:background">@drawable/widget_day_cell_empty</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#E2E8F0</item>
        <item name="android:textSize">11sp</item>
    </style>
</resources>
